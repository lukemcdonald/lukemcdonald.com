{
  "name": "luke-mcdonald-remix",
  "private": true,
  "description": "",
  "license": "",
  "scripts": {
    "build": "npm run build:css && remix build",
    "build:css": "postcss styles/tailwind.css -o ./app/styles/tailwind.css",
    "deploy": "fly --app lukemcdonald deploy .",
    "deploy:local": "fly deploy --local-only",
    "deploy:remote": "fly deploy --remote-only",
    "dev": "concurrently \"npm run dev:css\" \"remix dev\"",
    "dev:css": "postcss styles/tailwind.css -o ./app/styles/tailwind.css --watch",
    "format": "prettier --write .",
    "lint": "eslint --cache --cache-location ./node_modules/.cache/eslint .",
    "predeploy": "npm run build",
    "prepare": "husky install",
    "start": "remix-serve build/index.js"
  },
  "dependencies": {
    "@headlessui/react": "^2.2.3",
    "@heroicons/react": "^2.2.0",
    "@remix-run/node": "2.16.7",
    "@remix-run/react": "2.16.7",
    "@remix-run/serve": "2.16.7",
    "@tailwindcss/typography": "^0.5.16",
    "cloudinary": "^1.41.3",
    "cloudinary-build-url": "^0.2.4",
    "clsx": "^2.1.1",
    "front-matter": "^4.0.2",
    "marked": "^15.0.11",
    "postcss-import": "^16.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tiny-invariant": "^1.3.3",
    "use-local-storage-state": "^19.5.0"
  },
  "devDependencies": {
    "@cld-apis/types": "^0.1.6",
    "@remix-run/dev": "2.16.7",
    "@remix-run/eslint-config": "2.16.7",
    "@types/eslint": "^8.56.12",
    "@types/marked": "^6.0.0",
    "@types/react": "^18.3.22",
    "@types/react-dom": "^18.3.7",
    "@typescript-eslint/parser": "^6.21.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^8.2.2",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "husky": "^9.1.7",
    "postcss": "^8.5.3",
    "postcss-cli": "^10.1.0",
    "prettier": "^3.5.3",
    "prettier-plugin-tailwindcss": "^0.5.14",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3"
  },
  "eslintIgnore": [
    "/node_modules",
    "/build",
    "/public/build"
  ],
  "engines": {
    "node": ">=18"
  },
  "type": "module",
  "sideEffects": false
}
