{
  "name": "luke-mcdonald-remix",
  "private": true,
  "description": "",
  "license": "",
  "scripts": {
    "build": "npm run build:css && react-router build",
    "build:analyze": "npm run build:css && react-router build --analyze",
    "build:css": "postcss styles/tailwind.css -o ./app/styles/tailwind.css",
    "deploy": "fly --app lukemcdonald deploy .",
    "deploy:local": "fly deploy --local-only",
    "deploy:remote": "fly deploy --remote-only",
    "dev": "concurrently \"npm run dev:css\" \"NODE_OPTIONS='--import ./instrumentation.server.mjs' react-router dev\"",
    "dev:css": "postcss styles/tailwind.css -o ./app/styles/tailwind.css --watch",
    "fix": "npm run lint:fix && npm run format:fix",
    "format": "prettier ./app",
    "format:fix": "prettier ./app --write --ignore-unknown",
    "lint": "eslint ./app --report-unused-disable-directives",
    "lint:fix": "eslint ./app --fix --report-unused-disable-directives",
    "predeploy": "npm run build",
    "start": "NODE_OPTIONS='--import ./instrumentation.server.mjs' react-router-serve build/server/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@headlessui/react": "^2.2.4",
    "@heroicons/react": "^2.2.0",
    "@react-router/node": "^7.6.3",
    "@react-router/serve": "^7.6.3",
    "@sentry/react": "^9.34.0",
    "@sentry/react-router": "^9.35.0",
    "@tailwindcss/typography": "^0.5.16",
    "cloudinary": "^1.41.3",
    "cloudinary-build-url": "^0.2.4",
    "clsx": "^2.1.1",
    "concurrently": "^8.2.2",
    "front-matter": "^4.0.2",
    "isbot": "^5.1.28",
    "marked": "^15.0.12",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router": "^7.6.3",
    "tiny-invariant": "^1.3.3",
    "use-local-storage-state": "^19.5.0"
  },
  "devDependencies": {
    "@cld-apis/types": "^0.1.6",
    "@eslint/js": "^9.30.1",
    "@react-router/dev": "^7.6.3",
    "@sentry/cli": "^2.46.0",
    "@types/marked": "^6.0.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.30.1",
    "eslint-plugin-perfectionist": "^4.15.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.3.0",
    "postcss": "^8.5.6",
    "postcss-cli": "^10.1.0",
    "postcss-import": "^16.1.1",
    "prettier": "^3.5.3",
    "prettier-plugin-tailwindcss": "^0.5.14",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.35.1",
    "vite": "^7.0.1",
    "vite-tsconfig-paths": "^5.1.4"
  },
  "engines": {
    "node": ">=20"
  },
  "type": "module",
  "sideEffects": false
}
